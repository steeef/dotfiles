{
  "extraKnownMarketplaces": {
    "claude-hooks": {
      "source": {
        "source": "github",
        "repo": "steeef/claude-hooks"
      }
    }
  },
  "includeCoAuthoredBy": false,
  "includeGitInstructions": false,
  "spinnerTipsEnabled": false,
  "companyAnnouncements": [],
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(prek run:*)",
      "Bash(rg:*)",
      "Bash(yamllint:*)",
      "Bash(yq:*)"
    ],
    "deny": [
      "Bash(pre-commit:*)"
    ],
    "defaultMode": "plan"
  },
  "env": {
    "DISABLE_AUTO_COMPACT": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.bin/format.sh"
          }
        ]
      }
    ]
  }
}
